# ---------------------------------------------------------------------------
# QuinTron Breath Test — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# PostgreSQL connection string.
# POC: Vercel Postgres / Neon / Supabase. Production: UAE-region managed Postgres.
DATABASE_URL="postgresql://user:password@localhost:5432/quintron?schema=public"

# NextAuth — session signing secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-generate-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Field-level encryption key for patient PII/PHI (AES-256-GCM).
# MUST be 32 bytes, base64-encoded. Generate with: openssl rand -base64 32
# Rotating this key requires re-encrypting existing data — keep it safe.
PHI_ENCRYPTION_KEY="change-me-32-byte-base64-key"

# Application environment label shown in the audit log / UI banner.
APP_ENV="development"
