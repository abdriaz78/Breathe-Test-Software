{
  "name": "quintron-breath-test",
  "version": "0.1.0",
  "private": true,
  "description": "QuinTron Breath Test analyzer software — patient registration, test entry, charting, and signed PDF reporting for hospitals.",
  "scripts": {
    "predev": "npx --yes kill-port 3000",
    "dev": "next dev",
    "dev:clean": "npx --yes kill-port 3000 3001 3002 && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@react-pdf/renderer": "^4.5.1",
    "bcryptjs": "^2.4.3",
    "next": "15.1.11",
    "next-auth": "^4.24.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
